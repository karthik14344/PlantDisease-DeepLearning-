# ────────────────────────────────────────────────────
# Python
# ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST
.installed.cfg
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ────────────────────────────────────────────────────
# Virtual environments
# ────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
.env/
*.conda
conda-meta/

# ────────────────────────────────────────────────────
# IDE / Editor
# ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db
desktop.ini

# ────────────────────────────────────────────────────
# Jupyter
# ────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ────────────────────────────────────────────────────
# Raw Dataset (large, cite original source instead)
# ────────────────────────────────────────────────────
Pear/
!Pear/.gitkeep

# ────────────────────────────────────────────────────
# Processed Data (regenerated by prepare.py)
# ────────────────────────────────────────────────────
data/processed/images/
data/processed/labels/
data/interim/
data/raw/
# Keep small metadata files:
!data/processed/data.yaml
!data/processed/severity_labels.json
!data/processed/split_info.csv

# ────────────────────────────────────────────────────
# Model Weights (too large for git, share separately)
# ────────────────────────────────────────────────────
models/baselines/*/weights/
models/multitask/*/*.pt
models/multitask/*/*.pt.bak
*.pt
*.pth
*.onnx
*.engine
# But keep pretrained yolo*.pt NO — these auto-download, exclude
yolo*.pt
yolov*.pt

# ────────────────────────────────────────────────────
# Training artifacts
# ────────────────────────────────────────────────────
logs/
runs/
wandb/
mlruns/
lightning_logs/

# Keep training history JSONs (small, useful for plots)
!models/multitask/*/training_history.json
!models/baselines/*/metrics_summary.json

# ────────────────────────────────────────────────────
# Reports (regenerated by pipeline)
# ────────────────────────────────────────────────────
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.pdf
# Keep CSV and LaTeX tables (small, useful)
!reports/tables/*.csv
!reports/tables/*.tex
!reports/tables/*.json

# ────────────────────────────────────────────────────
# OS / Misc
# ────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.old
*.cache
.cache/
temp/
tmp/

# ────────────────────────────────────────────────────
# Secrets / Credentials
# ────────────────────────────────────────────────────
.env
.env.local
*.key
*.pem
secrets.json
credentials.json

# ────────────────────────────────────────────────────
# Large binaries
# ────────────────────────────────────────────────────
*.mp4
*.avi
*.zip
*.tar.gz
*.7z
